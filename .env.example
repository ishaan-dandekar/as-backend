# Environment Configuration
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOW_ALL_HOSTS_IN_DEBUG=True

# Database Configuration (MySQL)
DB_ENGINE=mysql
DB_NAME=project_hub
DB_USER=project_hub_user
DB_PASSWORD=project_hub_password
DB_HOST=127.0.0.1
DB_PORT=3306

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_ALL_ORIGINS_IN_DEBUG=True

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# GitHub API (Optional)
GITHUB_API_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/user/github/oauth/callback
GITHUB_OAUTH_SCOPE=read:user user:email repo
FRONTEND_APP_URL=http://localhost:3000

# LeetCode API (Optional)
LEETCODE_API_URL=https://leetcode.com/graphql

# Google OAuth (Optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
